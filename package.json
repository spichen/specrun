{
  "name": "specrun",
  "version": "0.1.0-beta1",
  "description": "Lightweight CLI agentic workflow framework",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spichen/specrun.git"
  },
  "homepage": "https://github.com/spichen/specrun",
  "bugs": {
    "url": "https://github.com/spichen/specrun/issues"
  },
  "keywords": [
    "cli",
    "agent",
    "workflow",
    "llm",
    "ai",
    "openai",
    "agentic"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "bin": {
    "specrun": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "openai": "^4.85.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
